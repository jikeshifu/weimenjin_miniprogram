<view class="big-box data-v-323a58da" style="padding-bottom:40rpx;"><view class="background data-v-323a58da"></view><view class="info-box data-v-323a58da"><view class="top-text data-v-323a58da">设备二维码，可打印张贴给用户使用</view><view class="qrcode data-v-323a58da"><image src="{{info.lock_qrcode}}" class="data-v-323a58da"></image></view><view class="cell-box data-v-323a58da"><view class="cell-item data-v-323a58da"><view class="label data-v-323a58da">网络标识：</view><block wx:if="{{info.iccid}}"><view class="value data-v-323a58da">{{info.iccid+''}}</view></block><block wx:if="{{info.iccid_status}}"><view data-event-opts="{{[['tap',[['iccidInfo',['$event']]]]]}}" class="bottom-btn data-v-323a58da" bindtap="__e">查续</view></block></view></view><view class="flex-box data-v-323a58da"><view class="cell-box data-v-323a58da"><view data-event-opts="{{[['tap',[['copySn',['$event']]]]]}}" class="cell-item data-v-323a58da" bindtap="__e"><view class="label data-v-323a58da">序列号：</view><block wx:if="{{info.lock_sn}}"><view class="value data-v-323a58da" style="color:#444444;">{{info.lock_sn}}</view></block></view><view class="cell-item data-v-323a58da"><view class="label data-v-323a58da">信号强度：</view><view class="value data-v-323a58da" style="{{(signalStyle)}}">{{signalDesc+" ("+info.rssi+")"}}</view></view></view><view class="cell-box data-v-323a58da"><block wx:if="{{$root.g0}}"><view class="cell-item data-v-323a58da"><view class="label data-v-323a58da">电池电量：</view><view data-event-opts="{{[['tap',[['powerInfo',['$event']]]]]}}" class="value data-v-323a58da" style="color:#21CF3E;" bindtap="__e">{{''+info.batterypower+''}}</view></view></block><view class="cell-item data-v-323a58da"><view class="label data-v-323a58da">固件版本：</view><block wx:if="{{info.version}}"><view class="value data-v-323a58da">{{info.version}}</view></block></view></view></view><view class="cell-box data-v-323a58da"><block wx:if="{{info.on_line_time}}"><view class="cell-item data-v-323a58da"><view class="label data-v-323a58da">上线时间：</view><block wx:if="{{info.on_line_time}}"><view data-event-opts="{{[['tap',[['onofflineInfo',['$event']]]]]}}" class="value data-v-323a58da" style="color:#21CF3E;" bindtap="__e">{{''+$root.m0+' 详情'}}</view></block></view></block></view></view><view data-event-opts="{{[['tap',[['saveImg',['$event']]]]]}}" class="save data-v-323a58da" bindtap="__e">保存二维码图片</view><block wx:if="{{info.qrServer_status}}"><view data-event-opts="{{[['tap',[['saveQr',['$event']]]]]}}" class="save data-v-323a58da" bindtap="__e">设置二维码到显示屏</view></block><block wx:if="{{info.addcardmode_status&&info.addcardmode==2}}"><view data-event-opts="{{[['tap',[['devAddCard',[1,'进入中']]]]]}}" class="save data-v-323a58da" bindtap="__e">进入发卡模式</view></block><block wx:if="{{info.addcardmode_status&&info.addcardmode!=2}}"><view data-event-opts="{{[['tap',[['devAddCard',[2,'退出中']]]]]}}" class="save data-v-323a58da" bindtap="__e">退出发卡模式</view></block><block wx:if="{{info.nonc_status&&info.noncmode==1}}"><view data-event-opts="{{[['tap',[['devNoNc',[0,'进入中']]]]]}}" class="save data-v-323a58da" bindtap="__e">进入常开模式</view></block><block wx:if="{{info.nonc_status&&info.noncmode!=1}}"><view data-event-opts="{{[['tap',[['devNoNc',[1,'退出中']]]]]}}" class="save data-v-323a58da" bindtap="__e">退出常开模式</view></block><view data-event-opts="{{[['tap',[['restartDevice',['$event']]]]]}}" class="save data-v-323a58da" bindtap="__e">重启设备</view></view>