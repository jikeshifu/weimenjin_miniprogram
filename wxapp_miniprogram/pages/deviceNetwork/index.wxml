<form>
  <view class="cu-form-group margin-top1" style="padding: 0px;">
    <view class="padding flex flex-direction" style="background: #ffffff; width: 100%;">
        <button class="cu-btn bg-green lg"  bindtap="search">查找附近设备</button>
      </view>    </view>
    <view class="cu-form-group margin-top1">
        <view class="title">设备序列号(SN)</view>
        <input name="lockcard_sn" placeholder="可点击查找附近设备获取" value="{{device_sn}}" bindinput="deviceSnSet"></input>
        <view class="picker locationbox" bindtap="bindScan">
            <view class="cuIcon-scan"></view>
        </view>
    </view>
    <view class="cu-form-group">
        <view class="title">Wi-Fi名称</view>
        <input name="lockcard_username" placeholder="" value="{{formData.wifi_name}}" bindinput="wifiNameSet"></input>
    </view>

    <view class="cu-form-group">
        <view class="title">Wi-Fi密码</view>
        <input name="lockcard_username"  placeholder="" value="{{formData.wifi_pwd}}" bindinput="wifiPwdSet"></input>
    </view>
    <view class="cu-form-group" hidden="true">
        <view class="title">设备密码</view>
        <input name="lockcard_username" type="password" placeholder="" value="{{formData.device_pwd}}" bindinput="devicePwdSet"></input>
    </view>

    <view class="padding flex flex-direction">
        <button class="cu-btn bg-green lg" bindtap="doSubmit">配网</button>
    </view>


    <view class=" flex flex-direction" style="padding: 20px 50rpx">
      <view class="title">1.本功能利用蓝牙给设备配置网络。</view>
      <view class="title">2.使用前请打开手机蓝牙。</view>
      <view class="title">3.确保设备进入配网模式。</view>
    </view>
    <view style="margin-top: 10rpx;color: #21cf3e">


    </view>

</form>
