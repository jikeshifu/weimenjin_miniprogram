<view class="wrap1">
  <scroll-view class="scrollbox" scroll-y style="height:{{scrollHeight}}px;" upper-threshold="50" lower-threshold="50" bindscrolltolower="bindscrolltolower" >

    <view class="listbox">
      <view class="listrow1" wx:for="{{List}}" wx:for-index="index" wx:for-item="vo" wx:key="id">

        <view class='shrink11'>
          <view class="name">{{vo.finger_name}}</view>

          <view class="gqtime">指纹id:{{vo.fp_id}}</view>
        </view>
        <view class='shrink01 delete' style="background: #39b54a;margin-right: 20rpx;" bindtap="pwdEdit" data-finger_id="{{vo.finger_id}}">编辑</view>
        <view class='shrink01 delete' bindtap="pwdDel" data-finger_id="{{vo.finger_id}}">删除</view>
      </view>
      <block wx:if="{{listlen <1}}">
        <view class="nodatabox">
          <view class="cuIcon-warn micon"></view>
          <view class="wz">没有数据</view>
        </view>
      </block>
      <view class="looding {{!hidelood ? 'hide': ''}}">
        <image mode="aspectFit" class="scanimg" src="{{looding}}"></image>
        <text class="lwz">正在加载</text>
      </view>
      <block wx:if="{{listlen > 12}}">
        <view class="looding {{!nodata ? 'hide': ''}}">
          <text class="lwz">不要再划了，没有啦！</text>
        </view>
      </block>
    </view>
  </scroll-view>

  <view class="addPwd"  bindtap="addPwd">
    添加指纹
  </view>

</view>
