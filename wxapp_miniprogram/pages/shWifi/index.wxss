.content {
    width: 100vw;
    height: 100vh;
   
  }
  .device{
    position: fixed;
    z-index: 99;
    top: 0;
    left: 0;
    height: 100vh;
    width: 100vw;
    overflow: hidden;
    background: rgba(12, 12, 12, 0.4);
  }
  .pop_up {
    position: fixed;
    z-index: 99;
    top: 0;
    left: 0;
    height: 100vh;
    width: 100vw;
    overflow: hidden;
    background: rgba(12, 12, 12, 0.4);
  }
  .ssid{
      position: relative;
      
  }
  .ssid .picker{
      display: flex;
      align-items: center;
      padding: 0 40rpx;
    color: black;
    margin-bottom: 40rpx;
    background-color: white;
    border: none;
    border-radius: 10rpx;
    height: 70rpx;
  }
 .ssid .scan{
    top: 10rpx;
    position: absolute;
    z-index: 22;
    right: 20rpx;
    width: 42rpx;
    height: 42rpx;
    font-size: 50rpx;
 }

  .pop_up .one {
    background: white;
    position: absolute;
    top: 35%;
    left: 50%;
    transform: translate(-50%, -35%);
    width: 600rpx;
    height: 700rpx;
  }
  
  .pop_up .one .icon {
    width: 100%;
    text-align: right;
    color: #000000;
    padding: 20rpx;
    box-sizing: border-box;
  }
  
  .pop_up .one .form {
    padding: 20rpx;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  
  .pop_up .one .form .inp {
    border: #579BB1 1px solid;
    padding: 0 10rpx;
    border-radius: 10rpx;
    width: 420rpx;
    height: 70rpx;
  }
  
  .pop_up .one .form .btn {
    width: 100rpx;
    background-color: #21cf3e;
    border-radius: 10rpx;
    color: #F5F5F5;
    height: 70rpx;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .pop_up .one .scroll-Y {
    height: 500rpx;
  }
  
  .pop_up .one .list {
    padding: 20rpx;
    box-sizing: border-box;
  }
  
  .pop_up .one .list .txt {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20rpx;
  }
  
  .pwd {
    position: relative;
  }
  
  .pwd_icon {
    top: 24rpx;
    position: absolute;
    z-index: 22;
    right: 20rpx;
    width: 32rpx;
    height: 32rpx;
  }
  
  .login {
    position: absolute;
    top: 35%;
    left: 50%;
    transform: translate(-50%, -35%);
    width: 600rpx;
    height: 600rpx;
  }
  
  .login .title {
    color: #555555;
    font-size: 42px;
    text-align: center;
    padding-bottom: 40rpx;
  }
  
  .login input {
    padding: 0 40rpx;
    color: black;
    margin-bottom: 40rpx;
    background-color: white;
    border: none;
    border-radius: 10rpx;
    height: 70rpx;
  }
  
  .icon {
    width: 60rpx;
    height: 60rpx;
  }
  
  .button {
    margin-bottom: 40px;
    background-color: #21cf3e;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    color: #F5F5F5;
    text-align: center;
  }
  
  span {
    color: gray;
    font-size: small;
  }
  